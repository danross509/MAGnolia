params {
    /***********************
        SYSTEM PARAMETERS
    ************************/
    lgThreads = 14
    lowThreads = 4
    lgMem = 256         // Memory available for large jobs
    mdMem = 64          // Memory available for medium jobs
    lowMem = 8          // Memory available for small jobs

    /***********************
        Module Management
    ************************/
    skip_qc = false
    skip_read_taxonomy = false
    skip_assembly = false
    skip_contig_taxonomy = false
    skip_binning = false
    skip_bin_refinement = true
    skip_binqc = true
    skip_classification = true
    skip_annotation = true

    /**************************
        Directory management
    ***************************/
    resultsDir = "${launchDir}"     // Where to save the results

    skip_database_download = false  // Only skip if all necessary databases are set (see below)
    databaseDownloadDir = "${launchDir}/databases" // Where to download 

    /* DATABASE DIRECTORIES */
    // Contig taxonomy
    kraken2_db = "/data/users/sarahpc/databases/kraken2_standard_database" // [null, "$PATH/to/existing/database"]
    bracken_build_exists = true // Has bracken been built for the specified kraken2db? Ensure that the details in READ & CONTIG TAXONOMY PARAMETERS match the existing build

    // Bin QC
    busco_db = null
    checkm_db = null
    checkm2_db = "/data/users/danross/databases/CheckM2/CheckM2_database/uniref100.KO.1.dmnd"
    checkm2_db_version = 5571251 // corresponds to Zenodo record  ID
    gunc_db = null

    // Bin taxonomy
    gtdb_db                              = "/data/users/danross/databases/GTDB_V08_R214/"
    gtdb_version                         = 2.3 // If using a gtdb database pre-r220, and therefore a download pre-2.4.0. This changes the summary.tsv produced by gtdb-tk
    //gtdb_db                              = "https://data.gtdb.ecogenomic.org/releases/release220/220.0/auxillary_files/gtdbtk_package/full_package/gtdbtk_r220_data.tar.gz"

    /* DATABASE DOWNLOADS */
    // Kraken2
    kraken2_build = '--standard' // ['--standard', '--special {greengenes,rdp,silva,gtdb}']
    kraken2_kmer_len = false // Integer. [Default: 35] Specify a desired kmer length
    kraken2_max_db_size = false // Integer. Maximum number of bytes for Kraken 2 hash table: [--max-db-size INT]


    /***************************
        READ INPUT PARAMETERS
    ****************************/

    // Input reads from samples.csv
    reads_file = "${launchDir}/samples.csv"

    // Short_reads
    short_reads = false // "${launchDir}/data/paired_X/*{1,2}.fastq.gz"
    paired_short_reads = false // [ true, false ] Are the short reads paired?
    short_reads_corrected = false // [ true, false ] Have the short reads been previously corrected?

    // Long reads
    nanopore_reads = false // "${launchDir}/data/nanopore/*"
    nanopore_hq = false // [ true, false ] Are the specified Nanopore heads hq (produced with chemistry v14+)?
    nanopore_reads_corrected = false // [ true, false ] Have the Nanopore reads been previously corrected?

    pacbio_reads = false
    pacbio_hifi = false // [ true, false ] Are the specified PacBio reads HiFi?
    pacbio_reads_corrected = false // [ true, false ] Have the PacBio reads been previously corrected?

    /******************************************
        QUALITY TRIMMING & FILTER PARAMETERS
    *******************************************/
    /* Host reference genome : will be used for short and/or long reads */
    host_genome = false // "/data/users/danross/FLONGLE_bacillus/Bacillus-subtilis-168-genome.fasta" // ['false', $path_to_fasta.fa]

    /* SHORT READ QC */
    skip_fastqc = false
    skip_short_read_trimming = false
    short_read_trimmer = 'fastp' // ['fastp', 'trimmomatic']
    fastp_adapter_sequences = null // ['adapter_sequence_R1', 'adapter_sequence_R2']
    fastp_auto_adapter_detection = true // [true, false]
    fastp_deduplication = true // [true, false]
    fastp_qualified_quality_phred = 15 // [Default = 15] Minimum phred value defined as qualified
    fastp_unqualified_percent_limit = 40 // [Default = 40] Percent of bases allowed below the qualified value
    fastp_disable_length_filtering = false // [true, false]
    fastp_length_required = 36 // Integer

    remove_phiX = true
    phiX = "${projectDir}/reference_genomes/phiX174_virus.fa"
    short_read_filter = 'bowtie2' // ['bowtie2', 'minimap2'] Bowtie2 is recommended for short reads. Minimap2 is available if desired
    bowtie2_sensitivity = 'very-sensitive-local'
    minimap2_short_read_preset = false // [Defaults to 'sr' when false]
    

    /* NANOPORE QC */
    skip_toulligqc = false
    toulligqc_input_type = 'fastq/ bam only' // ['sequencing_summary only', 'sequencing_summary + telemetry_source', 'telemetry_source + fast5', 'fastq/ bam only']
    toulligqc_sequencing_summary_source = [] // Basecaller sequencing summary source, can be compressed with gzip (.gz) or bzip2 (.bz2)
    toulligqc_telemetry_source = [] // Basecaller telemetry file source, can be compressed with gzip (.gz) or bzip2 (.bz2)
    toulligqc_fast5_source = [] // Fast5 file source
    toulligqc_bam_source = [] // BAM file source

    skip_fastplong = false

    minimap2_nanopore_preset = false // [Defaults to 'lr:hq' for hq or corrected reads, 'map-ont' otherwise] Also used in Binning preparation

    /* PACBIO QC */
    minimap2_pacbio_preset = false // [Defaults to 'map-hifi' for hifi or corrected reads, 'map-pb' otherwise] Also used in Binning preparation

    /*************************
        ASSEMBLY PARAMETERS
    **************************/
    //assembly_mode = 'per_sample' // ['per_sample', 'coassembly', 'grouped'] Defaults to 'coassembly' for <= 3 samples, otherwise 'per_sample'

    /* SHORT READ ASSEMBLY */
    assembler_short_reads = 'megahit' // ['hipmer', 'gatb', 'megahit', 'spades']
    // MEGAHIT pre-set parameters
    megahit_preset = 'meta-large'
    megahit_fix_cpu_1 = false
    additional_megahit_options = []
    // SPAdes pre-set parameters
    spades_use_meta = true // Runs SPAdes with "--meta" option, given paired reads
    additional_spades_options = []
    // HipMer pre-set parameters
    hipmer_depths = true
    // GATB pre-set parameters

    /* LONG READ ASSEMBLY*/
    assembler_long_reads = 'mdbg' // ['flye', 'canu', 'mdbg']
    // Flye pre-set parameters
    // If unspecified, read type will be determined using long-read input parameters (see above)
    flye_read_type = false // ['pacbio-raw', 'pacbio-corr', 'pacbio-hifi', 'nano-raw', 'nano-corr', 'nano-hq']
    flye_use_meta = true // Runs Flye with "--meta" option
    flye_genome_size = [] //
    // Canu pre-set parameters

    // MDBG pre-set parameters
    mdbg_generate_assembly_graph = false
    mdbg_assembly_graph_k = 21
    mdbg_assembly_graph_contigs = true
    mdbg_assembly_graph_reads = true

    /* HYBRID ASSEMBLY*/
    skip_spadeshybrid = true // set as false to assemble complementary short and long reads


    skip_quast = false
    skip_prodigal = false

    /***************************************
        READ & CONTIG TAXONOMY PARAMETERS
    ****************************************/
    skip_kracken2 = false
    kraken2_useNames = true // 
    kraken2_confidence = 0.0 // confidence score threshold (default: 0.0); must be in [0,1]
    kraken2_quick = false // Use quick operation (use first hit or hits)
    kraken2_preload_db = false // Preload full database into memory? Increases speed, but also RAM demand
    kraken2_minimizer = false // "--report-minimizer-data" : Report minimizer and distinct minimizer count information in addition to normal Kraken report
    kraken2_zero_counts = false // "--report-zero-counts" : Report counts for ALL taxa, even if counts are zero
    kraken2_minimum_hits = 2 // Minimum number of hit groups (overlapping k-mers sharing the same minimizer) needed to make a call (default 2)

    skip_krona = false // Generate taxonomy html visualizations with Krona 

    skip_bracken = false
    bracken_kmer_len = 35 // [default: 35 for Kraken2] Length of kmer used to build the database
    bracken_read_length = 100 // [default: 100] Ideal length of reads in your sample, as specified in bracken_build
    bracken_classification_level = 'G' // ['D','P','C','O','F','G','S'] Specifies the taxonomic rank to analyze.
    bracken_threshold = 10 // [Default = 10] Minimum number of reads required for a classification at the specified rank
    bracken_summary_NA = 'NA' // What value will be used in the abundance summary table for missing data (ie. taxa not present)

    skip_metaphlan4 = true


    /************************
        BINNING PARAMETERS
    *************************/

    //binning_mode = 'per_assembly' // ['per_assembly', 'cobinning', 'grouped'] Defaults to 'per_assembly'
    remove_unmapped = false // Set as true to remove unmapped reads (samtools view -b -F 4) from bam files of reads mapped to contig indices

    // Default binner for all reads
    skip_semibin2 = false
    use_semibin1 = false // SemiBin1 is deprecated, only use for back-compatibility
    semibin_environment = 'global' // ['human_gut', 'dog_gut', 'ocean', 'soil', 'cat_gut', 'human_oral', 'mouse_gut', 'pig_gut', 'built_environment', 'wastewater', 'chicken_caecum', 'global']

    // Short read oriented
    skip_aamb = true
    skip_vamb = true
    skip_comebin = true // Requires GPU
    skip_metabinner = true
    skip_metabat2 = false
    skip_maxbin2 = false
    skip_concoct = true
    // Uses assembly graphs
    skip_repbin = true
    skip_unitigbin = true
    skip_hmbin = true
    // Long read oriented
    skip_lrbinner = true
    min_contig_size = 1500
    min_length_unbinned_contigs = 1000000
    max_unbinned_contigs = 100

    bin_domain_classification_tool = 'tiara'
    skip_bin_domain_classification = true

    bin_refinement = 'dastool' // ['dastool', 'binette']
    refine_bins_dastool_threshold = 0.5

    postbinning_input = 'refined_bins_only' // ['refined_bins_only', 'raw_bins_only', 'both']
    exclude_unbins_from_postbinning = true

    // Bin QC
    binqc_tool                           = 'checkm2' // ['checkm', 'checkm2', 'busco']
    busco_auto_lineage_prok              = false
    save_busco_db                        = false
    busco_clean                          = false
    checkm_download_url                  = "https://zenodo.org/records/7401545/files/checkm_data_2015_01_16.tar.gz"
    save_checkm_data                     = false
    save_checkm2_data                    = false
    run_gunc                             = false
    gunc_database_type                   = 'progenomes'
    gunc_save_db                         = false

    // taxonomy options
    centrifuge_db                        = null
    skip_krona                           = false
    krona_db                             = null
    cat_db                               = null
    cat_db_generate                      = false
    cat_official_taxonomy                = false
    save_cat_db                          = false
    skip_gtdbtk                          = false
    gtdb_mash                            = null
    gtdbtk_min_completeness              = 50.0
    gtdbtk_max_contamination             = 10.0
    gtdbtk_min_perc_aa                   = 10
    gtdbtk_min_af                        = 0.65
    gtdbtk_pplacer_cpus                  = 1
    gtdbtk_pplacer_useram                = false

}

includeConfig "${projectDir}/configs/process_labels.config"

docker.fixOwnership = true
//docker.enabled = true
conda.enabled = true
executor.queueSize = 16
executor.cpus = 16

