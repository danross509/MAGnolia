process {

    cpus          = { 1 * task.attempt }
    memory        = { 7.GB * task.attempt }
    time          = { 4.h * task.attempt }

    errorStrategy = { task.exitStatus in ((130..145) + 104 + 2147483647) ? 'retry' : 'finish' }
    maxRetries    = 3
    maxErrors     = '-1'

    // Process-specific resource requirements
    // NOTE - Please try and reuse the labels below as much as possible.
    //        These labels are used and recognised by default in DSL2 files hosted on nf-core/modules.
    //        If possible, it would be nice to keep the same label naming convention when
    //        adding in your local modules too.
    // See https://www.nextflow.io/docs/latest/config.html#config-process-selectors

    withLabel: process_single {
        cpus   = { 1 }
        memory = { 6.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }
    withLabel: process_low {
        cpus   = { 2 * task.attempt <= params.maxCores ? 2 * task.attempt : params.maxCores }
        memory = { 12.GB * task.attempt <= params.maxMem ? 12.GB * task.attempt : params.maxMem }
        time   = { 4.h * task.attempt }
    }
    withLabel: process_medium {
        cpus   = { 6 * task.attempt <= params.maxCores ? 6 * task.attempt : params.maxCores }
        memory = { 36.GB * task.attempt <= params.maxMem ? 36.GB * task.attempt : params.maxMem }
        time   = { 8.h * task.attempt }
    }
    withLabel: process_high {
        cpus   = { 12 * task.attempt <= params.maxCores ? 12 * task.attempt : params.maxCores }
        memory = { 72.GB * task.attempt <= params.maxMem ? 72.GB * task.attempt : params.maxMem }
        time   = { 16.h * task.attempt }
    }
    withLabel: process_long {
        time = { 20.h * task.attempt }
    }
    withLabel: process_high_memory {
        memory = { 200.GB * task.attempt <= params.maxMem ? 200.GB * task.attempt : params.maxMem }
    }
    withLabel: error_ignore {
        errorStrategy = 'ignore'
    }
    withLabel: error_retry {
        errorStrategy = 'retry'
        maxRetries    = 2
    }

    withLabel: process_gpu {
        accelerator = { params.use_gpu ? 1 : null }
    }

    withName: PBTK_BAM2FASTQ {
        cpus   = { 6 * task.attempt }
        memory = { 12.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }

    //withName: BOWTIE2_PHIX_INDEX {
    //    cpus   = { 4 * task.attempt <= params.maxCores ? 4 * task.attempt : params.maxCores }
    //    memory = { 16.GB * task.attempt <= params.maxMem ? 16.GB * task.attempt : params.maxMem }
    //    time   = { 4.h * task.attempt }
    //}

    withName: BOWTIE2_HOST_INDEX {
        cpus   = { 10 * task.attempt <= params.maxCores ? 10 * task.attempt : params.maxCores }
        memory = { 20.GB * task.attempt <= params.maxMem ? 20.GB * task.attempt : params.maxMem }
        time   = { 4.h * task.attempt }
    }
    withName: BOWTIE2_FILTER_HOST {
        cpus   = { 10 * task.attempt <= params.maxCores ? 10 * task.attempt : params.maxCores }
        memory = { 10.GB * task.attempt <= params.maxMem ? 10.GB * task.attempt : params.maxMem }
        time   = { 6.h * task.attempt }
    }
    withName: BOWTIE2_FILTER_PHIX {
        cpus   = { 4 * task.attempt <= params.maxCores ? 4 * task.attempt : params.maxCores }
        memory = { 8.GB * task.attempt <= params.maxMem ? 8.GB * task.attempt : params.maxMem }
        time   = { 6.h * task.attempt }
    }/*
    withName: PORECHOP_PORECHOP {
        cpus   = { 4 * task.attempt }
        memory = { 30.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }
    withName: NANOLYSE {
        cpus   = { 2 * task.attempt }
        memory = { 10.GB * task.attempt }
        time   = { 3.h * task.attempt }
    }
    //filtlong: exponential increase of memory and time with attempts
    withName: FILTLONG {
        cpus   = { 8 * task.attempt }
        memory = { 64.GB * (2 ** (task.attempt - 1)) }
        time   = { 24.h * (2 ** (task.attempt - 1)) }
    }
    withName: CENTRIFUGE_CENTRIFUGE {
        cpus   = { 8 * task.attempt }
        memory = { 40.GB * task.attempt }
        time   = { 12.h * task.attempt }
    }*/
    withName: BRACKEN_BUILD {
        cpus   = { 12 * task.attempt <= params.maxCores ? 12 * task.attempt : params.maxCores }
        memory = { 240.GB * task.attempt <= params.maxMem ? 240.GB * task.attempt : params.maxMem }
        time   = { 24.h * task.attempt }
    }

    withName: KRAKEN2 {
        cpus   = { 8 * task.attempt <= params.maxCores ? 8 * task.attempt : params.maxCores }
        memory = {
            def base = params.kraken2_hashk2d_size + 5.GB
            def extra = 20.GB * (task.attempt - 1)
            def req = base + extra
            req <= params.maxMem ? req : params.maxMem 
        }
        time   = { 3.h * task.attempt }
        errorStrategy = { task.exitStatus in ((130..145) + 124 + 2147483647) ? 'retry' : 'ignore' }
        maxRetries    = 3
        maxErrors     = '-1'
    }
    withName: KRONA_K2_IMPORT_TAXONOMY {
        cpus   = { 8 * task.attempt <= params.maxCores ? 8 * task.attempt : params.maxCores }
        memory = { 20.GB * task.attempt <= params.maxMem ? 20.GB * task.attempt : params.maxMem }
        time   = { 12.h * task.attempt }
    }/*
    withName: CAT_DB_GENERATE {
        memory = { 200.GB * task.attempt }
        time   = { 16.h * task.attempt }
    }
    withName: CAT {
        cpus   = { 8 * task.attempt }
        memory = { 40.GB * task.attempt }
        time   = { 12.h * task.attempt }
    }*/

    withName: GTDB_DB_DOWNLOAD {
        cpus   = { 1 * task.attempt <= params.maxCores ? 1 * task.attempt : params.maxCores }
        memory = { 6.GB * task.attempt <= params.maxMem ? 6.GB * task.attempt : params.maxMem }
        time   = { 16.h * task.attempt }
    }

    withName: GTDBTK_CLASSIFYWF {
        cpus   = { 3 * task.attempt <= params.maxCores ? 3 * task.attempt : params.maxCores }
        memory = { 200.GB * task.attempt <= params.maxMem ? 200.GB * task.attempt : params.maxMem }
        time   = { 12.h * task.attempt }
    }
    //MEGAHIT returns exit code 250 when running out of memory
    withName: MEGAHIT {
        cpus          = { params.megahit_fix_cpu_1 ? 1 : (8 * task.attempt <= params.maxCores ? 8 * task.attempt : params.maxCores) }
        memory        = { 40.GB * task.attempt <= params.maxMem ? 40.GB * task.attempt : params.maxMem }
        time          = { 16.h * task.attempt }
        errorStrategy = { task.exitStatus in ((130..145) + 104 + 250 + 2147483647) ? 'retry' : 'finish' }
    }/*
    //SPAdes returns error(1) if it runs out of memory (and for other reasons as well...)!
    //exponential increase of memory and time with attempts, keep number of threads to enable reproducibility
    withName: SPADES {
        cpus          = { params.spades_fix_cpus != -1 ? params.spades_fix_cpus : (10 * task.attempt <= params.maxCores ? 10 * task.attempt : params.maxCores) }
        memory        = { 64.GB * (2 ** (task.attempt - 1)) }
        time          = { 24.h * (2 ** (task.attempt - 1)) }
        errorStrategy = { task.exitStatus in ((130..145) + 104 + 21 + 12 + 1) ? 'retry' : 'finish' }
        maxRetries    = 5
    }
    withName: SPADESHYBRID {
        cpus          = { params.spadeshybrid_fix_cpus != -1 ? params.spadeshybrid_fix_cpus : (10 * task.attempt) }
        memory        = { 64.GB * (2 ** (task.attempt - 1)) }
        time          = { 24.h * (2 ** (task.attempt - 1)) }
        errorStrategy = { task.exitStatus in ((130..145) + 104 + 21 + 12 + 1) ? 'retry' : 'finish' }
        maxRetries    = 5
    }*/

    //returns exit code 247 when running out of memory
    withName: BOWTIE2_BUILD_INDEX {
        cpus   = { 4 * task.attempt <= params.maxCores ? 4 * task.attempt : params.maxCores }
        memory = { 16.GB * task.attempt <= params.maxMem ? 16.GB * task.attempt : params.maxMem }
        time   = { 4.h * task.attempt }
    }
    //withName: BOWTIE2_ASSEMBLY_ALIGNMENT {
    //    cpus          = { 2 * task.attempt <= params.maxCores ? 2 * task.attempt : params.maxCores }
    //    memory        = { 8.GB * task.attempt <= params.maxMem ? 8.GB * task.attempt : params.maxMem }
    //    time          = { 8.h * task.attempt }
    //    errorStrategy = { task.exitStatus in ((130..145) + 104 + 247 + 2147483647) ? 'retry' : 'finish' }
    //}
    withName: METABAT2 {
        cpus   = { 8 * task.attempt <= params.maxCores ? 8 * task.attempt : params.maxCores }
        memory = { 20.GB * task.attempt <= params.maxMem ? 20.GB * task.attempt : params.maxMem }
        time   = { 8.h * task.attempt }
    }/*
    withName: MAG_DEPTHS {
        memory = { 16.GB * task.attempt }
    }
    withName: BUSCO_BUSCO {
        cpus          = { 10 * task.attempt }
        memory        = { 12.GB * task.attempt }
        errorStrategy = { task.exitStatus in (130..145) ? 'retry' : 'ignore' }
    }*/
    withName: MAXBIN2 {
        errorStrategy = { task.exitStatus in [1, 255] ? 'ignore' : 'retry' }
    }
    
    withName: CONCOCT_CONCOCT {
        cpus   = { 12 * task.attempt <= params.maxCores ? 12 * task.attempt : params.maxCores }
        memory = { 128.GB * task.attempt <= params.maxMem ? 128.GB * task.attempt : params.maxMem }
        time   = { 24.h * task.attempt }
    }
    
    withName: SEMIBIN2 {
        cpus          = { 12 * task.attempt <= params.maxCores ? 12 * task.attempt : params.maxCores }
        memory        = { 200.GB * task.attempt <= params.maxMem ? 128.GB * task.attempt : params.maxMem }
        time          = { 24.h * task.attempt }
        errorStrategy = { task.exitStatus in ((130..145) + 104 + 2147483647) ? 'retry' : 'ignore' }
    }

    withName: COMEBIN {
        cpus          = { 12 * task.attempt <= params.maxCores ? 12 * task.attempt : params.maxCores }
        memory        = { 128.GB * task.attempt <= params.maxMem ? 128.GB * task.attempt : params.maxMem }
        time          = { 16.h * task.attempt }
        errorStrategy = { task.exitStatus in [1, 255] ? 'ignore' : 'retry' }
    }
    
    withName: VAMB_BIN {
        cpus          = { 12 * task.attempt <= params.maxCores ? 12 * task.attempt : params.maxCores }
        memory        = { 128.GB * task.attempt <= params.maxMem ? 128.GB * task.attempt : params.maxMem }
        time          = { 16.h * task.attempt }
    }

    withName: LRBINNER {
        cpus   = { 12 * task.attempt <= params.maxCores ? 12 * task.attempt : params.maxCores }
        memory = { 200.GB * task.attempt <= params.maxMem ? 200.GB * task.attempt : params.maxMem }
        time   = { 20.h * task.attempt }
    }/*
    withName: DASTOOL_DASTOOL {
        errorStrategy = { task.exitStatus in ((130..145) + 104) ? 'retry' : task.exitStatus == 1 ? 'ignore' : 'finish' }
    }
    //as per https://github.com/Ecogenomics/CheckM/wiki/Installation#system-requirements
    withName: CHECKM_LINEAGEWF {
        memory = 42.GB
    }
    //CheckM2 returns exit code 1 when Diamond doesn't find any hits
    withName: CHECKM2_PREDICT {
        errorStrategy = { task.exitStatus in (130..145) ? 'retry' : task.exitStatus == 1 ? 'ignore' : 'finish' }
    }*/
}