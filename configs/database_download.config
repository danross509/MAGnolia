params {
    /*************************
        Database parameters
    **************************/
    // Read + Contig taxonomy
    kraken2_db = "/data/users/sarahpc/databases/kraken2_standard_database"      // [false, "$PATH/to/existing/database"]
    bracken_build_exists = true                                                 // Has bracken been built for the specified kraken2db? 
                                                                                // Ensure that the details in READ & CONTIG TAXONOMY PARAMETERS match the existing build                                           

    // Bin QC
    //busco_db = null
    checkm_db = null
    checkm2_db = "/data/users/danross/databases/CheckM2/CheckM2_database/uniref100.KO.1.dmnd"
    checkm2_db_version = 5571251                                                                // corresponds to Zenodo record  ID

    // Bin taxonomy
    gtdb_db = "/data/users/danross/databases/GTDB_V08_R214/"
    gtdb_version = 2.3                                          // If using a gtdb database pre-r220, and therefore a download pre-2.4.0. 
                                                                // This changes the summary.tsv produced by gtdb-tk
    gtdb_download = "https://data.gtdb.ecogenomic.org/releases/release220/220.0/auxillary_files/gtdbtk_package/full_package/gtdbtk_r220_data.tar.gz"

    // Bin annotation
    // If you already have DRAM installed, use <DRAM-setup.py export_config > my_config.txt> to create a config file
    dram_config_loc = "/data/users/danross/WRAP/JL/all/full_drep_50/DRAM_99/my_old_config.txt"      // [false, "$PATH/to/existing/my_config.txt"]

    /**************************
        Database downloads
    ***************************/
    databaseDownloadDir = "${launchDir}/databases"      // Directory to download new databases
    skip_database_download = false                      // Only skip if all necessary databases are set

    // Kraken2
    kraken2_build = '--standard'            // ['--standard', '--special {greengenes,rdp,silva,gtdb}']
    kraken2_kmer_len = false                // Integer. [Default: 35] Specify a desired kmer length
    kraken2_max_db_size = false             // Integer. Maximum number of bytes for Kraken 2 hash table: [--max-db-size INT]

    // DRAM
    dram_kegg_loc = false                   // [false, "$PATH/to/kegg.pep"] kegg.pep is the path to the amino acid FASTA file downloaded from KEGG
    dram_skip_uniref = true                 // [true, false] Installing uniref requires ~5hrs and 512Gb RAM

}

process {
    // Kraken2 download

    // QUAST

    // CheckM, CheckM2 downloads

    // DRAM download
    withName: DRAM_PREPARE_DB {
        // Add existing individual db locations using the --{db_name}_loc flags such as --uniref_loc and --viral_loc
        ext.args = [""].join(' ').trim() 
    }

    // GTDB download

}