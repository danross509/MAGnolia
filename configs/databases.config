params {
    /*************************
        Database parameters
    **************************/
    // Read + Contig taxonomy
    kraken2_db = false              // [false, "$PATH/to/existing/database"]
    bracken_build_exists = false    // Has bracken been built for the specified kraken2db? 
                                    // Ensure that the details in READ & CONTIG TAXONOMY PARAMETERS match the existing build                                           

    // Bin evaluation
    //busco_db = null
    checkm2_db = false      // [false, "$PATH/to/existing/database/CheckM2_database/uniref100.KO.1.dmnd"]
    checkm_db = false       // [false, "$PATH/to/existing/database/CheckM_database"]

    // Bin taxonomy
    gtdb_db = false             // [false, "$PATH/to/existing/gtdb/directory/"]
    gtdb_version = '2.6.1'      // Specify the gtdb version - full compatibility details at https://ecogenomics.github.io/GTDBTk/installing/index.html
                                // release226 is compatible with v2.4.1+
                                // release220 is compatible with v2.4.0*
                                // release214 is compatible with v2.1.0-v2.3.2
    gtdbtk_use_tmp_pplacer_dir = true

    // Bin annotation
    bakta_db = false            // [false, "$PATH/to/existing/bakta/db"]
    // If you already have DRAM installed, use <DRAM-setup.py export_config > my_config.txt> to create a config file
    dram_config_loc = false     // [false, "$PATH/to/existing/my_config.txt"]

    /**************************
        Database downloads
    ***************************/
    databaseDownloadDir = "${params.resultsDir}/databases"      // Directory to download new databases
    skip_database_download = false                      // Only skip if all necessary databases are set

    // Kraken2
    kraken2_build = '--standard'            // ['--standard', '--special {greengenes,rdp,silva,gtdb}']
    kraken2_kmer_len = false                // Integer. [Default: 35] Specify a desired kmer length
    kraken2_max_db_size = false             // Integer. Maximum number of bytes for Kraken 2 hash table: [--max-db-size INT] ex "10GiB", "4TB", "10 gebibytes", "4 terabytes"

    // Bracken
    bracken_memory_map = false               // Use --memory-mapping parameter during bracken-build. Will default to true if maxMem < 240.GB

    // CheckM2
    checkm2_db_version = 5571251            // corresponds to Zenodo record  ID
    checkm2_download_dir = "${params.databaseDownloadDir}/checkm2" 

    // CheckM
    checkm_download_url = "https://zenodo.org/records/7401545/files/checkm_data_2015_01_16.tar.gz"

    // Bakta
    bakta_download_dir = "${params.databaseDownloadDir}/bakta"
    bakta_type = 'light'                    // ['light', 'full'] Use 'light' for faster runtime or to conserve storage

    // DRAM
    dram_kegg_loc = false                   // [false, "$PATH/to/kegg.pep"] kegg.pep is the path to the amino acid FASTA file downloaded from KEGG
    dram_skip_uniref = true                 // [true, false] Installing uniref requires ~5hrs and 512Gb RAM

    // GTDB
    gtdb_download = "https://data.gtdb.aau.ecogenomic.org/releases/release226/226.0/auxillary_files/gtdbtk_package/full_package/gtdbtk_r226_data.tar.gz"

}

process {
    // Kraken2 download

    // QUAST

    // CheckM, CheckM2 downloads

    // Bakta download
    withName: BAKTA_BAKTADBDOWNLOAD {
        ext.args = ["--type ${params.bakta_type}"
            ].join(' ').trim()
    }

    // DRAM download
    withName: DRAM_PREPARE_DB {
        // Add existing individual db locations using the --{db_name}_loc flags such as --uniref_loc and --viral_loc
        ext.args = [""].join(' ').trim() 
    }

    // GTDB download

}